<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- HEADER -->
    <ImageView
        android:id="@+id/headerResult"
        android:layout_width="0dp"
        android:layout_height="240dp"
        android:scaleType="fitXY"
        android:src="@drawable/header_curve"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pendaftaran Berhasil!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginStart="24dp"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="@id/headerResult"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- CONTENT -->
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="20dp"
        android:elevation="8dp"
        android:layout_margin="20dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/headerResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtNama"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama: "
            android:textColor="@color/text_light"/>

        <TextView
            android:id="@+id/txtEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email: "
            android:layout_marginTop="8dp"
            android:textColor="@color/text_light"/>

        <TextView
            android:id="@+id/txtNoHp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No HP: "
            android:layout_marginTop="8dp"
            android:textColor="@color/text_light"/>

        <TextView
            android:id="@+id/txtGender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gender: "
            android:layout_marginTop="8dp"
            android:textColor="@color/text_light"/>

        <TextView
            android:id="@+id/txtSeminar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seminar: "
            android:layout_marginTop="8dp"
            android:textColor="@color/text_light"/>

        <Button
            android:id="@+id/btnBack"
            android:text="Kembali ke beranda"
            android:background="@drawable/button_primary"
            android:textColor="@color/white"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>